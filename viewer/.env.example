# ── DB / Auth ────────────────────────────────────────────
DB_PASSWORD=change-me
JWT_SECRET=change-me-to-a-long-random-string

# ── Google OAuth (선택) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lecture.example.com/api/auth/google/callback

# ── 채팅 기능 ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-sonnet-4-6

# ── 업로드 파이프라인 (extract_and_correct.py 실행용) ────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STT_PROVIDER=elevenlabs
CORRECTION_MODEL=gpt-5.4
DOMAIN_DETECTION=auto
# 파이프라인 내부 동시 처리 (트랜스크립션/교정)
MAX_WORKERS=20

# ── 업로드 작업 큐 워커 풀 ───────────────────────────────
# 동시에 처리할 업로드 job 수 (예: 30)
WORKER_POOL_SIZE=30
# 워커가 DB 큐를 폴링하는 주기 (초)
WORKER_POLL_INTERVAL=5
# 업로드 최대 크기 (bytes). 기본 8GB.
MAX_UPLOAD_BYTES=8589934592
