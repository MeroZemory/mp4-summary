# MP4 Summary Pipeline Configuration
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=

# STT Provider: "elevenlabs" (화자분리 지원) 또는 "whisper"
STT_PROVIDER=elevenlabs

# 파이프라인 내부 동시 처리 워커 (트랜스크립션 청크/교정 배치)
MAX_WORKERS=20

# GPT 교정 모델
CORRECTION_MODEL=gpt-5.4

# Anthropic API (교정 백엔드 및 ShowMe 생성용)
ANTHROPIC_API_KEY=

# 도메인 감지: "auto", "generic", 또는 특정 도메인 ID
DOMAIN_DETECTION=auto
